# Calmindra Frontend Environment Variables
# Copy this file to .env for custom configurations.

# URL of the running FastAPI backend server.
# For local dev, defaults to http://localhost:8000 (no .env required).
# For production (e.g. Vercel), set this to your deployed FastAPI backend URL.
BACKEND_URL=http://localhost:8000

# Shared secret sent only by the Next.js server to the FastAPI backend.
# Must match BACKEND_API_SECRET in the backend deployment.
BACKEND_API_SECRET=replace-with-the-same-secret-as-backend

# Auth.js / NextAuth
# Generate with: npx auth secret
AUTH_SECRET=replace-with-a-long-random-secret

# Public app URL used by OAuth providers.
AUTH_URL=http://localhost:3000

# Optional OAuth providers. Configure one or both in production.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Optional: separate HMAC secret for deriving non-email backend user IDs.
# Defaults to AUTH_SECRET when omitted.
AUTH_BACKEND_ID_SECRET=

# Local development only. Enables a simple dev login on /sign-in.
# Do not set this in production.
AUTH_DEV_PASSWORD=
